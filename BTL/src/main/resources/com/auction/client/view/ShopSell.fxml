<!--<?xml version="1.0" encoding="UTF-8"?>-->
<!---->
<!--<?import javafx.geometry.Insets?>-->
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<?import javafx.geometry.Insets?>
<VBox prefHeight="1080.0" prefWidth="1831.0" styleClass="main-root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.ShopSellController">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="100.0" spacing="20.0" styleClass="header">
            <children>
                <Label styleClass="logo-text" text="MY SHOP" />
                <Label styleClass="header-sub-title" text="&gt; Sản phẩm chờ đăng bán" />
                <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleBackClicked" prefHeight="45.0" prefWidth="103.0" styleClass="btn3" text="Quay lại" />
                <TextField promptText="Tìm trong kho..." styleClass="search-input-small" />
            </children>
            <padding>
                <Insets left="60.0" right="60.0" />
            </padding>
        </HBox>

        <VBox spacing="30.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
            </padding>
            <children>
                <TableView fx:id="productTable" styleClass="custom-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colSTT" prefWidth="60.0" text="STT" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colName" prefWidth="300.0" text="Tên sản phẩm" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colPrice" prefWidth="150.0" text="Giá khởi điểm" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colDesc" prefWidth="300.0" text="Mô tả" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colStatus" prefWidth="150.0" text="Trạng thái" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colAction" prefWidth="150.0" text="Thao tác" style="-fx-alignment: CENTER;" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="20.0">
                    <children>
                        <Label fx:id="totalLabel" styleClass="label-value" text="Tổng cộng: 0 sản phẩm đang chờ" />
                        <Button styleClass="btn-submit" text="Đăng sản phẩm đã chọn lên Auction" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
