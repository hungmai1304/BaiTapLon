<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.admin.AdminOnlineAuctions"
            prefHeight="400.0" prefWidth="750.0">
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
            <children>

                <Label text="Quản Lý Danh Sách Đấu Giá Trực Tuyến" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

                <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNo" prefWidth="50.0" text="STT" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colId" prefWidth="80.0" text="ID Sản phẩm" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colProductName" prefWidth="180.0" text="Tên sản phẩm" />
                        <TableColumn fx:id="colOwner" prefWidth="140.0" text="Người đăng (Owner)" />

                        <TableColumn fx:id="colStatus" prefWidth="130.0" text="Trạng thái" style="-fx-alignment: CENTER;" />

                        <TableColumn fx:id="colAction" prefWidth="150.0" text="Thao tác" style="-fx-alignment: CENTER;" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

            </children>
        </VBox>
    </children>
</AnchorPane>