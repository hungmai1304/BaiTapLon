<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="635.0" prefWidth="1009.0" styleClass="main-container" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.login.LoginController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    <children>
        <AnchorPane fx:id="sideDecoration" layoutX="350.0" prefHeight="500.0" prefWidth="500.0" styleClass="purple-side-bg">
         <children>
      
                          <AnchorPane layoutX="-53.0" layoutY="6.0" prefHeight="625.0" prefWidth="708.0" style="-fx-background-color: transparent;">
                  <children>
      
                                  <VBox alignment="CENTER" layoutX="366.0" layoutY="151.0" prefWidth="300.0" spacing="10.0">
                          <children>
                              <Label styleClass="welcome-main" text="AUCTIONX" />
                              <Label styleClass="welcome-sub" text="Welcome Back !" />
                        <Label text="Bid Fast, Win Smart !" textFill="WHITE" />
                              <Label alignment="CENTER" prefWidth="240.0" styleClass="welcome-desc" text="Realtime Auction Experience" textAlignment="CENTER" wrapText="true" />
                          </children>
                      </VBox>
                  </children>
              </AnchorPane>
         </children></AnchorPane>
          <VBox alignment="CENTER" layoutX="61.0" layoutY="148.0" prefWidth="280.0" spacing="20.0">
              <children>
                  <Label styleClass="title-login" text="Login" />
                  <VBox spacing="5.0">
                      <Label styleClass="label-input" text="Email" />
                      <TextField fx:id="mail" styleClass="flat-field" />
                  </VBox>
                  <VBox spacing="5.0">
                      <Label styleClass="label-input" text="Password" />
                      <PasswordField fx:id="passwordtext" styleClass="flat-field" />
                  </VBox>
            <CheckBox fx:id="rememberMe" mnemonicParsing="false" text="Remember Me" textFill="#a88bff" />
            <Label textFill="WHITE" />
                  <Label fx:id="announcement" styleClass="msg-label" />
                  <Button onAction="#handleGetText" prefHeight="40.0" prefWidth="280.0" styleClass="btn-login" text="Login" />
                  <HBox alignment="CENTER" spacing="5.0">
                      <Label styleClass="small-text" text="Don't have an account?" />
                      <Hyperlink onAction="#handleButtonClick" styleClass="link-text" text="Sign Up" />
                  </HBox>
              </children>
          </VBox>
    </children>
</AnchorPane>
