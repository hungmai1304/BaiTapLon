<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox prefHeight="1080.0" prefWidth="1831.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox alignment="TOP_CENTER" styleClass="hero-section" VBox.vgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="40.0">
                    <children>
                        <Label styleClass="logo-text" text="Search" />
                        <Label styleClass="sub-logo" text="Help Center" />
                        <Region HBox.hgrow="ALWAYS" />
                    </children>
                    <padding>
                        <Insets bottom="40.0" left="80.0" right="80.0" top="40.0" />
                    </padding>
                </HBox>

                <VBox alignment="CENTER" spacing="40.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label styleClass="main-title" text="Search Auction Here" />
                        <HBox alignment="CENTER" maxWidth="1000.0" styleClass="search-container">
                            <children>
                                <TextField promptText="Find answers (design help, password, billing)" styleClass="search-field" HBox.hgrow="ALWAYS" />
                                <Button styleClass="btn-search" text="Search" />
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="100.0" />
                    </padding>
                </VBox>
            </children>
        </VBox>

        <HBox alignment="CENTER" spacing="60.0" styleClass="cards-section">
            <children>
                <VBox alignment="CENTER" styleClass="info-card">
                    <children>
                        <Circle fill="#00c4cc" radius="60.0" styleClass="card-icon" />
                        <Label styleClass="card-title" text="Electric" />
                    </children>
                </VBox>
                <VBox alignment="CENTER" styleClass="info-card">
                    <children>
                        <Circle fill="#82bc41" radius="60.0" styleClass="card-icon" />
                        <Label styleClass="card-title" text="Home" />
                    </children>
                </VBox>
                <VBox alignment="CENTER" styleClass="info-card">
                    <children>
                        <Circle fill="#ffcc00" radius="60.0" styleClass="card-icon" />
                        <Label styleClass="card-title" text="Art" />
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets bottom="100.0" top="100.0" />
            </padding>
        </HBox>
    </children>
</VBox>
