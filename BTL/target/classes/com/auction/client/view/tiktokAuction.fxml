<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Line?>

<VBox prefHeight="1080.0" prefWidth="1831.0" styleClass="main-container" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="80.0" styleClass="header">
            <children>
                <Label styleClass="header-title" text="Tik Tok Auction:" />
            </children>
            <padding>
                <Insets left="40.0" />
            </padding>
        </HBox>

        <HBox spacing="40.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="20.0" />
            </padding>
            <children>

                <HBox spacing="20.0" styleClass="content-card" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="30.0" left="20.0" right="30.0" top="30.0" />
                    </padding>
                    <children>

                        <VBox alignment="CENTER" spacing="20.0" prefWidth="80.0">
                            <children>
                                <Button styleClass="product-nav-btn" text="▲" />
                                <Label styleClass="product-counter" text="02" />
                                <Separator opacity="0.2" maxWidth="40"/>
                                <Label styleClass="product-counter-total" text="10" />
                                <Button styleClass="product-nav-btn" text="▼" />
                            </children>
                        </VBox>

                        <VBox spacing="30.0" HBox.hgrow="ALWAYS">
                            <children>
                                <StackPane styleClass="image-container" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="image-placeholder" text="Ảnh insert từ khách" />
                                        <HBox alignment="CENTER" spacing="550.0">
                                            <children>
                                                <Button styleClass="nav-button-circle" text="&lt;" />
                                                <Button styleClass="nav-button-circle" text="&gt;" />
                                            </children>
                                        </HBox>
                                    </children>
                                </StackPane>

                                <VBox spacing="15.0" styleClass="info-section">
                                    <children>
                                        <Label styleClass="label-value-highlight" text="SẢN PHẨM ĐANG CHỌN #02" />
                                        <HBox spacing="10.0">
                                            <Label styleClass="label-title" text="Tên sản phẩm:" />
                                            <Label styleClass="label-value" text="iPhone 15 Pro Max New Seal" />
                                        </HBox>
                                        <HBox spacing="10.0">
                                            <Label styleClass="label-title" text="Giá khởi điểm:" />
                                            <Label styleClass="label-value" text="2,500,000 VNĐ" />
                                        </HBox>
                                        <HBox spacing="10.0">
                                            <Label styleClass="label-title" text="Bước giá:" />
                                            <Label styleClass="label-value" text="50,000 VNĐ" />
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <Line endY="800.0" stroke="#A7D3A6" strokeWidth="2.0" opacity="0.3" />

                <VBox spacing="30.0" styleClass="content-card" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                    </padding>
                    <children>
                        <VBox spacing="10.0">
                            <children>
                                <Label styleClass="section-title" text="Người dẫn đầu hiện tại" />
                                <HBox alignment="CENTER_LEFT" styleClass="leader-box">
                                    <children>
                                        <Label styleClass="leader-name" text="Nguyễn Văn A - 1,500,000 VNĐ" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label styleClass="section-title" text="Chat:" />
                                <TextArea editable="false" styleClass="chat-area" text="Hệ thống: Phiên đấu giá bắt đầu!&#10;User123: 1,100,000&#10;Admin: Chúc các bạn may mắn..." VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>

                        <HBox spacing="30.0">
                            <children>
                                <Button maxWidth="Infinity" styleClass="btn-bid" text="Đấu giá" HBox.hgrow="ALWAYS" />
                                <Button maxWidth="Infinity" styleClass="btn-bot" text="BotBid" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>